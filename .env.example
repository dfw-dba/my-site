# Database
POSTGRES_USER=mysite
POSTGRES_PASSWORD=localdev
POSTGRES_DB=mysite
DATABASE_URL=postgresql+asyncpg://mysite:localdev@db:5432/mysite

# MinIO (S3-compatible storage for local dev)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MEDIA_BUCKET=media

# Backend
ADMIN_API_KEY=local-dev-admin-key
CORS_ORIGINS=http://localhost:5173

# AWS (production only)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=  (leave blank for real S3, set for MinIO)
