{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "component": "my-site",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": "frontend/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "infrastructure/cdk/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "toml",
          "path": "backend/pyproject.toml",
          "key": "project.version"
        },
        {
          "type": "generic",
          "path": "backend/src/app/_version.py"
        }
      ]
    }
  },
  "last-release-sha": "824c4ff2d90f5f66d681ae4b0b54b6584ae235ac"
}
