FROM public.ecr.aws/lambda/python:3.13

# Install uv for fast dependency resolution
RUN pip install --no-cache-dir uv

# Copy dependency spec and install
COPY backend/pyproject.toml ${LAMBDA_TASK_ROOT}/
RUN uv pip install --system --no-cache -r ${LAMBDA_TASK_ROOT}/pyproject.toml

# Copy application source
COPY backend/src/ ${LAMBDA_TASK_ROOT}/src/

CMD ["src.lambda_handler.handler"]
